{
  "name": "video-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.ts,.jsx,.tsx",
    "lint:fix": "eslint . --ext .vue,.js,.ts,.jsx,.tsx --fix",
    "format": "prettier --write --ignore-path .gitignore .",
    "format:check": "prettier --check --ignore-path .gitignore .",
    "lint:format": "pnpm run lint:fix && pnpm run format"
  },
  "dependencies": {
    "artplayer": "^5.3.0",
    "axios": "^1.13.2",
    "dayjs": "^1.11.19",
    "element-plus": "^2.11.8",
    "json-bigint": "^1.0.0",
    "lodash-es": "^4.17.21",
    "pinia": "^3.0.4",
    "sass": "^1.94.2",
    "vue": "^3.5.25",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/tsconfig": "^0.8.1",
    "@vueuse/core": "^14.0.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-vue": "^10.6.1",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.6.2",
    "rollup": "^4.53.3",
    "terser": "^5.44.1",
    "typescript": "^5.9.3",
    "unplugin-auto-import": "^20.2.0",
    "unplugin-vue-components": "^30.0.0",
    "vite": "^7.2.4",
    "vite-plugin-environment": "^1.1.3",
    "vue-tsc": "^3.1.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0",
    "pnpm": ">=9.0.0"
  },
  "lint-staged": {
    "*.{vue,js,ts,jsx,tsx}": [
      "pnpm run lint:fix",
      "pnpm run format"
    ],
    "*.{css,scss,json,md}": [
      "pnpm run format"
    ]
  }
}
